<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>How it Works</title>
    <link rel="stylesheet" href="/css/howItWorks.css">
</head>
<body>
    <%- include('partials/navbar.ejs') %>

    
    <section class="how-it-works">

  <!-- Heading -->
  <h1 class="main-heading">
    Built on Rigorous <br>
    <span><i>Science.</i></span>
  </h1>

  <!-- Description -->
  <p class="description">
    <b>
    Understanding the chemical makeup of everyday products shouldn't be a mystery.
    Here's how our multi-layered analytical pipeline decodes your products.</b>
  </p>

</section>


<!-- NOTE -->


<div class="note-section">
  <div class="note-icon">⚠️</div>

  <div class="note-content">
    <h2>Important Note</h2>
    <p>
      Please enter only <strong>one chemical at a time</strong>. 
      Multiple inputs may lead to inaccurate or incomplete analysis results.
    </p>
  </div>
</div>



<section class="process-section">

  <!-- Cards -->
  <div class="cards-container">

    <div class="card">
      <div class="icon-box">🔍</div>
      <h3>Data Acquisition</h3>
      <p>
        Paste the complex ingredient list from any consumer product. Our system
        handles raw text and chemical nomenclature with precision.
      </p>
    </div>

    <div class="card">
      <div class="icon-box">🧠</div>
      <h3>Neural Synthesis</h3>
      <p>
        Our AI engine cross-references each token against global toxicology
        databases, research papers, and regulatory lists (EU/FDA).
      </p>
    </div>

    <div class="card">
      <div class="icon-box">🛡️</div>
      <h3>Risk Calibration</h3>
      <p>
        Receive a weighted safety score and a comprehensive toxicity breakdown
        grouped by immediate and long-term biological risks.
      </p>
    </div>

  </div>

  

  <!-- Big Info Card -->
  <div class="info-card">
    <div class="info-icon">🗄️</div>

    <div class="info-content">
      <span class="tag">CORE SECURITY PROTOCOL</span>

      <h2>Enterprise-Grade Toxicology Data</h2>

      <p class="info-text">
        "Our system evaluates ingredients against the World Health Organization (WHO)
        safety standards, the EU Cosmetics Regulation annexes, and current peer-reviewed
        clinical research to provide an objective evidence-based report."
      </p>

      <div class="info-footer">
        <span>VALIDATED INDEX v4.2</span>
        <span>99.8% ANALYSIS COVERAGE</span>
      </div>
    </div>
  </div>

</section>
<%- include('partials/footer') %>
</body>
</html>